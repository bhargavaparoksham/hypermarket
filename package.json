{
  "name": "hypermarket",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:test:up": "docker run --name hypermarket-postgres-test -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=hypermarket_test -p 54329:5432 -d postgres:16-alpine",
    "db:test:start": "docker start hypermarket-postgres-test",
    "db:test:stop": "docker stop hypermarket-postgres-test",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --check .",
    "test": "pnpm --filter @hypermarket/contracts test && pnpm --filter @hypermarket/engine test",
    "test:contracts": "pnpm --filter @hypermarket/contracts test",
    "test:db": "pnpm --filter @hypermarket/engine test:db:local",
    "test:engine": "pnpm --filter @hypermarket/engine test",
    "test:full": "pnpm test && pnpm test:db",
    "dev": "pnpm -r --parallel --if-present dev",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.12",
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
